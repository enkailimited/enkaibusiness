{
  "name": "enkai-business",
  "version": "0.1.0",
  "private": true,
  "description": "Intelligent business operating platform for Africa and emerging markets",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:assign-owner-roles": "tsx scripts/assign-owner-roles.ts",
    "db:reset": "prisma migrate reset",
    "db:warm": "tsx -e \"const{prisma}=require('./src/server/db');prisma.$queryRaw\\`SELECT 1\\`.then(()=>{console.log('DB awake');process.exit(0)}).catch(e=>{console.error(e);process.exit(1)})\"",
    "auth:generate": "npx @better-auth/cli generate",
    "auth:migrate": "npx @better-auth/cli migrate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.6.14",
    "@better-auth/utils": "^0.4.1",
    "@prisma/client": "^6.1.0",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tanstack/react-query": "^5.62.7",
    "better-auth": "^1.6.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "motion": "^12.40.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.4",
    "nodemailer": "^8.0.11",
    "pg": "^8.21.0",
    "pg-boss": "^12.23.0",
    "react": "^19.0.7",
    "react-dom": "^19.0.7",
    "react-dropzone": "^14.3.5",
    "react-hook-form": "^7.54.1",
    "tailwind-merge": "^2.6.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "bcryptjs": "^2.4.3",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.3",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
