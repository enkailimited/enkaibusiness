// ═══════════════════════════════════════════════════════════════════════════════
// CROSS-CUTTING
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Notification ────────────────────────────────────────────────────────────

model Notification {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  workspaceId   String?   @map("workspace_id") @db.Uuid
  businessId    String?   @map("business_id") @db.Uuid
  branchId      String?   @map("branch_id") @db.Uuid
  title         String
  message       String?
  type          String // "alert" | "info" | "warning" | "success" | "sale" | "payment" | "inventory" | "subscription"
  channel       String    @default("in_app") // "in_app" | "email" | "sms"
  referenceType String?   @map("reference_type")
  referenceId   String?   @map("reference_id")
  isRead        Boolean   @default(false) @map("is_read")
  readAt        DateTime? @map("read_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  business  Business?  @relation(fields: [businessId], references: [id])

  @@index([userId, isRead])
  @@index([businessId])
  @@index([createdAt])
  @@map("notifications")
}

// ─── Notification Preference ──────────────────────────────────────────────────

model NotificationPreference {
  id         String  @id @default(uuid()) @db.Uuid
  userId     String  @map("user_id") @db.Uuid
  businessId String? @map("business_id") @db.Uuid
  event      String // "sale_completed" | "payment_received" | "low_stock" | etc.
  inApp      Boolean @default(true) @map("in_app")
  email      Boolean @default(false)
  sms        Boolean @default(false)

  user     User?     @relation(fields: [userId], references: [id])
  business Business? @relation(fields: [businessId], references: [id])

  @@unique([userId, businessId, event])
  @@index([userId])
  @@map("notification_preferences")
}

// ─── Activity ────────────────────────────────────────────────────────────────

model Activity {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  action       String
  resourceType String   @map("resource_type")
  resourceId   String   @map("resource_id")
  metadata     Json?    @default("{}")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("activities")
}

// ─── AuditLog ────────────────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  action       String
  resourceType String   @map("resource_type")
  resourceId   String   @map("resource_id")
  before       Json?    @default("{}")
  after        Json?    @default("{}")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Upload ──────────────────────────────────────────────────────────────────

model Upload {
  id           String   @id @default(uuid()) @db.Uuid
  businessId   String   @map("business_id") @db.Uuid
  uploadedById String   @map("uploaded_by") @db.Uuid
  fileName     String   @map("file_name")
  fileUrl      String   @map("file_url")
  fileId       String   @map("file_id")
  thumbnailUrl String?  @map("thumbnail_url")
  size         Int
  mimeType     String   @map("mime_type")
  folder       String?  @default("general")
  tags         String?  @default("")
  createdAt    DateTime @default(now()) @map("created_at")

  business   Business @relation(fields: [businessId], references: [id])
  uploadedBy User     @relation("UploadCreatedBy", fields: [uploadedById], references: [id])

  @@index([businessId])
  @@map("uploads")
}

// ─── Setting ─────────────────────────────────────────────────────────────────

model Setting {
  id          String   @id @default(uuid()) @db.Uuid
  businessId  String?  @map("business_id") @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  key         String
  value       String // JSON-encoded
  type        String // "string", "number", "boolean", "json"
  description String?
  isPublic    Boolean  @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  business Business? @relation(fields: [businessId], references: [id])
  user     User?     @relation("SettingUser", fields: [userId], references: [id])

  @@unique([businessId, key])
  @@unique([userId, key])
  @@index([businessId])
  @@index([key])
  @@map("settings")
}

// ═══════════════════════════════════════════════════════════════════════════════
// EMAIL & COMMUNICATIONS
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Email Config (SMTP) ──────────────────────────────────────────────────────

model EmailConfig {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String?  @map("business_id") @db.Uuid
  name       String
  host       String
  port       Int      @default(587)
  username   String
  password   String // encrypted at rest
  encryption String   @default("tls") // "tls" | "ssl" | "none"
  fromEmail  String
  fromName   String?
  isDefault  Boolean  @default(false) @map("is_default")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  business Business? @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@map("email_configs")
}

// ─── Email Template ───────────────────────────────────────────────────────────

model EmailTemplate {
  id               String   @id @default(uuid()) @db.Uuid
  businessId       String?  @map("business_id") @db.Uuid
  name             String
  slug             String
  subject          String
  htmlContent      String   @map("html_content")
  plainTextContent String?  @map("plain_text_content")
  variables        Json? // ["customerName", "businessName", ...]
  isSystem         Boolean  @default(false) @map("is_system")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  business  Business?  @relation(fields: [businessId], references: [id])
  emailLogs EmailLog[]
  campaigns Campaign[]

  @@unique([businessId, slug])
  @@index([businessId])
  @@map("email_templates")
}

// ─── Email Log ────────────────────────────────────────────────────────────────

model EmailLog {
  id           String    @id @default(uuid()) @db.Uuid
  businessId   String?   @map("business_id") @db.Uuid
  templateId   String?   @map("template_id") @db.Uuid
  campaignId   String?   @map("campaign_id") @db.Uuid
  recipient    String
  subject      String
  status       String // "sent" | "delivered" | "opened" | "clicked" | "bounced" | "failed"
  errorMessage String?   @map("error_message")
  sentAt       DateTime? @map("sent_at")
  openedAt     DateTime? @map("opened_at")
  clickedAt    DateTime? @map("clicked_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  template EmailTemplate? @relation(fields: [templateId], references: [id])
  campaign Campaign?      @relation(fields: [campaignId], references: [id])

  @@index([businessId])
  @@index([campaignId])
  @@index([status])
  @@map("email_logs")
}

// ─── Campaign Segment ─────────────────────────────────────────────────────────

model CampaignSegment {
  id            String   @id @default(uuid()) @db.Uuid
  businessId    String?  @map("business_id") @db.Uuid
  name          String
  description   String?
  criteria      Json // Targeting criteria as JSON
  customerCount Int      @default(0) @map("customer_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  business  Business?  @relation(fields: [businessId], references: [id])
  campaigns Campaign[]

  @@index([businessId])
  @@map("campaign_segments")
}

// ─── Campaign ─────────────────────────────────────────────────────────────────

model Campaign {
  id              String    @id @default(uuid()) @db.Uuid
  businessId      String?   @map("business_id") @db.Uuid
  name            String
  description     String?
  segmentId       String?   @map("segment_id") @db.Uuid
  templateId      String?   @map("template_id") @db.Uuid
  type            String    @default("email") // "email" | "sms"
  status          String    @default("draft") // "draft" | "scheduled" | "sending" | "sent" | "paused" | "cancelled"
  scheduledAt     DateTime? @map("scheduled_at")
  sentAt          DateTime? @map("sent_at")
  sentCount       Int       @default(0) @map("sent_count")
  deliveredCount  Int       @default(0) @map("delivered_count")
  openedCount     Int       @default(0) @map("opened_count")
  clickedCount    Int       @default(0) @map("clicked_count")
  failedCount     Int       @default(0) @map("failed_count")
  totalRecipients Int       @default(0) @map("total_recipients")
  createdById     String?   @map("created_by") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  business   Business?           @relation(fields: [businessId], references: [id])
  segment    CampaignSegment?    @relation(fields: [segmentId], references: [id])
  template   EmailTemplate?      @relation(fields: [templateId], references: [id])
  createdBy  User?               @relation("EmailCampaignCreatedBy", fields: [createdById], references: [id])
  recipients CampaignRecipient[]
  emailLogs  EmailLog[]

  @@index([businessId])
  @@index([status])
  @@map("campaigns")
}

// ─── Firdaus Persistent Workflow ─────────────────────────────────────────────

enum FirdausWorkflowStatus {
  STARTED
  COLLECTING_DATA
  VALIDATING
  EXECUTING
  COMPLETED
  FAILED
}

model FirdausWorkflow {
  id          String                  @id @default(uuid()) @db.Uuid
  businessId  String                  @map("business_id") @db.Uuid
  userId      String                  @map("user_id") @db.Uuid
  type        String                  // "sales" | "purchases" | "expenses" | "inventory" | "customers" | "suppliers" | "business_setup"
  status      FirdausWorkflowStatus   @default(STARTED)
  currentStep String                  @default("") @map("current_step")
  collectedData Json                  @default("{}") @map("collected_data")
  context      Json                  @default("{}")
  error       String?                 @map("error")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([businessId, userId])
  @@index([businessId, status])
  @@index([type, status])
  @@map("firdaus_workflows")
}

// ─── Business Learned Memory ─────────────────────────────────────────────────

enum MemoryType {
  PREFERRED_SUPPLIER
  TOP_CUSTOMER
  COMMON_EXPENSE
  POPULAR_PRODUCT
  PAYMENT_METHOD
  FREQUENT_PRODUCT
}

model BusinessMemory {
  id         String     @id @default(uuid()) @db.Uuid
  businessId String     @map("business_id") @db.Uuid
  type       MemoryType
  key        String     // e.g. supplier name, product name, category
  value      String     // e.g. supplier name, count as text
  confidence Float      @default(0.5) // 0.0 – 1.0
  metadata   Json?      @default("{}")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id])

  @@unique([businessId, type, key])
  @@index([businessId, type])
  @@map("business_memory")
}

// ─── Campaign Recipient ───────────────────────────────────────────────────────

model CampaignRecipient {
  id           String    @id @default(uuid()) @db.Uuid
  campaignId   String    @map("campaign_id") @db.Uuid
  customerId   String?   @map("customer_id") @db.Uuid
  email        String
  status       String    @default("pending") // "pending" | "sent" | "delivered" | "opened" | "clicked" | "failed"
  sentAt       DateTime? @map("sent_at")
  openedAt     DateTime? @map("opened_at")
  clickedAt    DateTime? @map("clicked_at")
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at")

  campaign Campaign? @relation(fields: [campaignId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([campaignId])
  @@index([status])
  @@map("campaign_recipients")
}
