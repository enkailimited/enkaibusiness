// SUPPORT
// ═══════════════════════════════════════════════════════════════════════════════

// ─── SupportTicket ───────────────────────────────────────────────────────────

model SupportTicket {
  id           String         @id @default(uuid()) @db.Uuid
  title        String
  description  String?
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(MEDIUM)
