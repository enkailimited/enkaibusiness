// ─── CommissionPayout ────────────────────────────────────────────────────────

model CommissionPayout {
  id        String   @id @default(uuid()) @db.Uuid
  amount    Decimal  @db.Decimal(15, 2)
  notes     String?
  paidById  String?  @map("paid_by") @db.Uuid
  paidAt    DateTime @default(now()) @map("paid_at")
  createdAt DateTime @default(now()) @map("created_at")

  entries CommissionLedger[] @relation("PayoutEntries")
  paidBy  User?              @relation("PayoutPaidBy", fields: [paidById], references: [id])

  @@map("commission_payouts")
}

// ═══════════════════════════════════════════════════════════════════════════════
// QR ORDERING
// ═══════════════════════════════════════════════════════════════════════════════

// ─── DistributionCampaign ────────────────────────────────────────────────────

model DistributionCampaign {
  id           String         @id @default(uuid()) @db.Uuid
  name         String
  slug         String         @unique
  description  String?
  totalQRCodes Int            @default(0) @map("total_qr_codes")
  status       CampaignStatus @default(DRAFT)
  startDate    DateTime?      @map("start_date")
  endDate      DateTime?      @map("end_date")
  createdById  String?        @map("created_by") @db.Uuid
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  createdBy User?    @relation("CampaignCreatedBy", fields: [createdById], references: [id])
  qrCodes   QRCode[]

  @@index([status])
  @@map("distribution_campaigns")
}

// ─── QRCode ──────────────────────────────────────────────────────────────────

model QRCode {
  id           String       @id @default(uuid()) @db.Uuid
  campaignId   String       @map("campaign_id") @db.Uuid
  code         String       @unique
  businessId   String?      @map("business_id") @db.Uuid
  status       QRCodeStatus @default(UNASSIGNED)
  assignedToId String?      @map("assigned_to") @db.Uuid
  mode         String?      // "retail", "wholesale", "restaurant", "general"
  installedAt  DateTime?    @map("installed_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  campaign      DistributionCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  business      Business?            @relation("BusinessQRCodes", fields: [businessId], references: [id])
  menuItems     QRMenuItem[]
  assignments   QRCodeAssignment[]
  installations QRCodeInstallation[]

  @@index([campaignId])
  @@index([status])
  @@index([assignedToId])
  @@map("qr_codes")
}

// ─── QRMenuItem ──────────────────────────────────────────────────────────────

model QRMenuItem {
  id            String   @id @default(uuid()) @db.Uuid
  businessId    String   @map("business_id") @db.Uuid
  qrCodeId      String   @map("qr_code_id") @db.Uuid
  catalogItemId String   @map("catalog_item_id") @db.Uuid
  isAvailable   Boolean  @default(true) @map("is_available")
  sortOrder     Int      @default(0) @map("sort_order")
  price         Decimal? @db.Decimal(15, 2)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  business    Business    @relation(fields: [businessId], references: [id])
  qrCode      QRCode      @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  catalogItem CatalogItem @relation(fields: [catalogItemId], references: [id])

  @@unique([qrCodeId, catalogItemId])
  @@index([qrCodeId])
  @@map("qr_menu_items")
}

// ─── QRCodeAssignment ────────────────────────────────────────────────────────

model QRCodeAssignment {
  id         String   @id @default(uuid()) @db.Uuid
  qrCodeId   String   @map("qr_code_id") @db.Uuid
  assignedTo String   @map("assigned_to")
  assignedBy String   @map("assigned_by")
  notes      String?
  assignedAt DateTime @default(now()) @map("assigned_at")
  createdAt  DateTime @default(now()) @map("created_at")

  qrCode QRCode @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)

  @@index([qrCodeId])
  @@map("qr_code_assignments")
}

// ─── QRCodeInstallation ──────────────────────────────────────────────────────

model QRCodeInstallation {
  id          String   @id @default(uuid()) @db.Uuid
  qrCodeId    String   @map("qr_code_id") @db.Uuid
  businessId  String   @map("business_id") @db.Uuid
  location    String?
  installedBy String   @map("installed_by")
  notes       String?
  installedAt DateTime @default(now()) @map("installed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  qrCode   QRCode   @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  business Business @relation("BusinessQRInstallations", fields: [businessId], references: [id])

  @@index([qrCodeId])
  @@index([businessId])
  @@map("qr_code_installations")
}

