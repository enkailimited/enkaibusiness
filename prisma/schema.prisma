  name             String
  hierarchyLevelId String?        @map("hierarchy_level_id") @db.Uuid
  type             CommissionType
  value            Decimal        @db.Decimal(10, 2)
  minAmount        Decimal?       @map("min_amount") @db.Decimal(15, 2)
  maxAmount        Decimal?       @map("max_amount") @db.Decimal(15, 2)
  isActive         Boolean        @default(true) @map("is_active")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  hierarchyLevel SalesHierarchy? @relation("SalesHierarchyRules", fields: [hierarchyLevelId], references: [id])

  @@index([hierarchyLevelId])
  @@map("commission_rules")
}

// ─── CommissionLedger ────────────────────────────────────────────────────────

model CommissionLedger {
  id             String                 @id @default(uuid()) @db.Uuid
  salesProfileId String                 @map("sales_profile_id") @db.Uuid
  subscriptionId String?                @map("subscription_id") @db.Uuid
  payoutId       String?                @map("payout_id") @db.Uuid
  amount         Decimal                @db.Decimal(15, 2)
  type           CommissionType
  description    String?
